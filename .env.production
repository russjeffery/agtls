# Loaded by `next build` (which `opennextjs-cloudflare build` runs).
# NEXT_PUBLIC_* values are inlined into the client bundle at build time, so the
# production origin has to be known here — Worker vars are too late for these.
# (`npm run deploy:preview` overrides it via the shell for the preview origin.)
# Server-only runtime vars like BETTER_AUTH_URL come from wrangler.jsonc vars,
# NOT this file, so the preview environment can use its own origin.
NEXT_PUBLIC_APP_URL="https://agtls.dev"
