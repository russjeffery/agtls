# Database
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# BetterAuth
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
# Local dev: http://localhost:3000 — Production: https://agtls.dev
BETTER_AUTH_URL="http://localhost:3000"

# App — this URL is the origin for the published auth.md / discovery documents
# and the ID-JAG audience, so it must match the deployment.
# Local dev: http://localhost:3000 — Production: https://agtls.dev
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Agent auth (auth.md) — trusted agent providers for the agent-verified flow.
# JSON array of { iss, name?, jwksUri?, clientId? }. SECURITY-CRITICAL: only
# list providers whose ID-JAG assertions you trust. Leave unset to disable the
# agent-verified flow (the user-claimed flows still work). jwksUri defaults to
# `{iss}/.well-known/jwks.json`.
# AGENT_AUTH_TRUSTED_PROVIDERS='[{"iss":"https://auth.openai.com","name":"OpenAI"}]'

# Scheduled messages — secret guarding POST /api/messages/dispatch (the endpoint
# a scheduler calls to deliver due messages). Callers must send it as
# `Authorization: Bearer <secret>` (the scheme Vercel Cron uses). Leave unset to
# leave the endpoint open — fine for local dev, but set it in any deployment.
# CRON_SECRET="generate-with: openssl rand -base64 32"

# Social sign-in (optional). Leave a provider unset to hide its button on the
# sign-in/sign-up pages. Callback URLs to register with the provider:
#   GitHub: {BETTER_AUTH_URL}/api/auth/callback/github
#   Google: {BETTER_AUTH_URL}/api/auth/callback/google
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
